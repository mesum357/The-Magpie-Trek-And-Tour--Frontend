<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= trip.title %> - Recent Trip</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=HK+Grotesk:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/home.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <style>
    .trip-detail-hero {
      height: 60vh;
      min-height: 400px;
      background-size: cover;
      background-position: center;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .trip-detail-hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.6));
    }

    .trip-hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      color: white;
      max-width: 800px;
      padding: 20px;
    }

    .trip-hero-title {
      font-size: 3.5rem;
      font-weight: 700;
      text-shadow: 0 4px 15px rgba(0,0,0,0.5);
      margin-bottom: 20px;
    }

    .trip-hero-desc {
      font-size: 1.5rem;
      opacity: 0.9;
      text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    .trip-content-section {
      padding: 80px 0;
      background-color: #fff;
    }

    .trip-main-content {
        line-height: 1.8;
        font-size: 1.15rem;
        color: #444;
    }

    .trip-main-content h2 {
        color: var(--navy-900);
        font-weight: 700;
        margin-top: 40px;
        margin-bottom: 20px;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 50px;
    }

    .gallery-item {
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      aspect-ratio: 4 / 3;
      cursor: pointer;
      transition: transform 0.3s ease;
    }

    .gallery-item:hover {
      transform: scale(1.03);
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--teal-600);
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 30px;
        transition: transform 0.3s ease;
    }

    .back-btn:hover {
        color: var(--teal-700);
        transform: translateX(-5px);
    }

    @media (max-width: 768px) {
        .trip-hero-title {
            font-size: 2.5rem;
        }
        .trip-hero-desc {
            font-size: 1.2rem;
        }
        .trip-content-section {
            padding: 50px 0;
        }
    }
  </style>
</head>

<body class="trip-detail-body">
  <%- include('partials/navbar', { user: user, isAuthenticated: isAuthenticated, currentPage: 'recent-trips' }) %>

  <% 
    var mainImageUrl = trip.imageUrl;
    if (mainImageUrl && !mainImageUrl.startsWith('http') && !mainImageUrl.startsWith('data:')) {
        mainImageUrl = adminBaseUrl + (mainImageUrl.startsWith('/') ? '' : '/') + mainImageUrl;
    }
  %>

  <section class="trip-detail-hero" style="background-image: url('<%= mainImageUrl %>');">
    <div class="trip-hero-content">
      <h1 class="trip-hero-title"><%= trip.title %></h1>
      <p class="trip-hero-desc"><%= trip.description %></p>
    </div>
  </section>

  <section class="trip-content-section">
    <div class="container">
        <a href="/" class="back-btn">
            <i class="bi bi-arrow-left"></i> Back to Home
        </a>
        
        <div class="row">
            <div class="col-lg-10 mx-auto">
                <div class="trip-main-content">
                    <h2 class="mb-4">Details About <%= trip.title %></h2>
                    <div style="white-space: pre-line;">
                        <%= trip.fullDescription %>
                    </div>
                </div>

                <% if (trip.gallery && trip.gallery.length > 0) { %>
                <div class="mt-5 pt-5 border-top">
                    <h2 class="text-center mb-5">Image Gallery</h2>
                    <div class="gallery-grid">
                        <% trip.gallery.forEach(function(imgUrl) { 
                            var fullGalleryUrl = imgUrl;
                            if (fullGalleryUrl && !fullGalleryUrl.startsWith('http') && !fullGalleryUrl.startsWith('data:')) {
                                fullGalleryUrl = adminBaseUrl + (fullGalleryUrl.startsWith('/') ? '' : '/') + fullGalleryUrl;
                            }
                        %>
                        <div class="gallery-item" onclick="openLightbox('<%= fullGalleryUrl %>')">
                            <img src="<%= fullGalleryUrl %>" alt="<%= trip.title %> Gallery Image">
                        </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>
  </section>

  <!-- Simple Lightbox Modal -->
  <div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-body p-0 text-center">
                <img id="lightboxImg" src="" class="img-fluid rounded shadow-lg" style="max-height: 90vh;">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
        </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function openLightbox(url) {
        document.getElementById('lightboxImg').src = url;
        const modal = new bootstrap.Modal(document.getElementById('lightboxModal'));
        modal.show();
    }
  </script>

  <%- include('partials/footer') %>
</body>

</html>
